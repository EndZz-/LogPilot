{
  "name": "logpilot",
  "version": "0.2.0",
  "description": "Smart log file organizer and viewer",
  "main": "dist-electron/main/index.js",
  "author": {
    "name": "LogPilot"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "make": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.3.9",
    "fuse.js": "^7.0.0",
    "react-dom": "^19.2.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "com.logpilot.app",
    "productName": "LogPilot",
    "artifactName": "${productName}_${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "EndZz-",
      "repo": "LogPilot",
      "releaseType": "release"
    },
    "files": [
      "dist-electron/**/*",
      "resources/icon/icon.png"
    ]
  }
}
